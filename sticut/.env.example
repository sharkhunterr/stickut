# Stickut V1 — environment configuration template.
# Copy this file to `.env` and tune as needed.
# All variables are optional; defaults are sensible for a homelab deployment.
#
# IMPORTANT : pas de commentaires en fin de ligne sur les lignes KEY=VALUE.
# systemd EnvironmentFile= ne les strip pas, et la variable contiendrait le
# commentaire (=> ValidationError au démarrage).

# Limits
STICKUT_MAX_FILE_SIZE_MB=20
STICKUT_MAX_FILES_PER_SESSION=50

# Cutout pipeline (modèles : birefnet-general | isnet-general-use | u2net | isnet-anime)
STICKUT_DEFAULT_MODEL=birefnet-general
# clamp to nb_cpu at runtime
STICKUT_REMBG_WORKERS=2

# Filesystem (default to in-image paths; override only if you have custom mounts)
# STICKUT_CACHE_DIR=/app/cache
# STICKUT_TEMPLATES_DIR=/app/templates
# STICKUT_TMP_DIR=/app/tmp

# Sessions — TTL en secondes avant purge de tmp/{session_id}/
STICKUT_TMP_TTL_SECONDS=3600

# Networking
STICKUT_PORT=8000
# true derrière un reverse proxy (Authentik / Nginx Proxy Manager) — sinon false
STICKUT_BEHIND_PROXY=true

# --- Online image search (off par défaut, constitution: no runtime network) ----
STICKUT_ENABLE_SEARCH=false
# Si vide → fallback Openverse (sans clé). Sinon → Pixabay (clé gratuite sur
# https://pixabay.com/api/docs/, 5000 req/h, qualité curatée).
STICKUT_PIXABAY_API_KEY=
STICKUT_SEARCH_TIMEOUT_SECONDS=10
